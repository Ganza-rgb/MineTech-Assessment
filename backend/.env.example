# ---- Server ----
PORT=4000

# ---- MySQL (cPanel / remote) ----
# cPanel often provides a remote host; use it here.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=db_user
MYSQL_PASSWORD=db_pass
MYSQL_DATABASE=minetech

# ---- LLM provider ----
# 'cloud' = Hugging Face Inference API (fast, no local download, needs HF token)
# 'local' = self-hosted Hugging Face model via Transformers.js (ONNX, CPU/GPU)
# 'mock'  = deterministic offline provider (no model download, runs anywhere)
LLM_MODE=cloud

# Cloud inference settings
CLOUD_PROVIDER=hf
CLOUD_API_URL=https://api-inference.huggingface.co
CLOUD_API_KEY=hf_...
CLOUD_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Local HF model settings (used when LLM_MODE=local)
HF_MODEL_ID=onnx-community/Qwen2.5-0.5B-Instruct
HF_DTYPE=q4

# Embedding model for RAG (ONNX). all-MiniLM-L6-v2 is 384-dim, CPU-friendly.
HF_EMBED_MODEL_ID=Xenova/all-MiniLM-L6-v2

# Generation parameters
LLM_TEMP=0.7
LLM_MAX_TOKENS=128

# Device: 'cpu' | 'webgpu' | 'wasm' | 'cuda'
TRANSFORMERS_DEVICE=cpu

# ---- RAG ----
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=4
RAG_SIM_THRESHOLD=0.2
RAG_LEXICAL_WEIGHT=0.3
