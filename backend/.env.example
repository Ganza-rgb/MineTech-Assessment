# ---- Server ----
PORT=4000

# ---- MySQL (optional - needed for triage feature only) ----
# If MySQL is not available, RAG still works but tickets won't be saved
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=1234
MYSQL_DATABASE=minetech

# ---- LLM Mode ----
# Only 'ollama' is supported (self-hosted, no external APIs)
LLM_MODE=ollama

# ---- Ollama Settings ----
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b                 # Model for text generation
OLLAMA_EMBED_MODEL=nomic-embed-text       # Dedicated embedding model (768-dim)

# Generation parameters
LLM_TEMP=0.1                              # Low temp for factual consistency
LLM_MAX_TOKENS=256

# ---- RAG Settings ----
RAG_CHUNK_SIZE=600                       # Tokens per chunk
RAG_CHUNK_OVERLAP=100                     # Overlap between chunks
RAG_TOP_K=5                               # Number of chunks to retrieve
RAG_SIM_THRESHOLD=0.35                    # Minimum similarity threshold