# ---- Server ----
PORT=4000

# ---- MySQL ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=minetech

# ---- LLM provider ----
# 'ollama' = self-hosted Ollama (no external APIs)
# 'mock'   = deterministic offline provider (no model download)
LLM_MODE=ollama

# Ollama settings
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Generation parameters
LLM_TEMP=0.7
LLM_MAX_TOKENS=256

# ---- RAG ----
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=4
RAG_SIM_THRESHOLD=0.2
RAG_LEXICAL_WEIGHT=0
